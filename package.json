{
  "name": "codexkit-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:cli-artifact": "npm run build && node scripts/build-cli-artifact.mjs",
    "pack:cli": "npm_config_cache=.npm-cache npm pack --workspace @codexkit/cli",
    "smoke:cli:tarball": "node scripts/smoke-cli-tarball.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "TMPDIR=.tmp vitest run tests/unit tests/integration && TMPDIR=.tmp vitest run tests/runtime --no-file-parallelism",
    "impact:claudekit-source-graph": "node scripts/knowledge/claudekit-source-impact.mjs",
    "smoke:claudekit-source-graph": "node scripts/knowledge/claudekit-source-query-smoke.mjs",
    "validate:claudekit-source-graph": "node scripts/knowledge/validate-claudekit-source-graph.mjs",
    "validate:claudekit-source-graph:wave1": "node scripts/knowledge/validate-claudekit-source-graph.mjs --profile wave1",
    "test:unit": "TMPDIR=.tmp vitest run tests/unit",
    "test:integration": "TMPDIR=.tmp vitest run tests/integration",
    "test:runtime": "TMPDIR=.tmp vitest run tests/runtime --no-file-parallelism"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
