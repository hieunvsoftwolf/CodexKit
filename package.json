{
  "name": "codexkit-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "TMPDIR=.tmp vitest run",
    "impact:claudekit-source-graph": "node scripts/knowledge/claudekit-source-impact.mjs",
    "smoke:claudekit-source-graph": "node scripts/knowledge/claudekit-source-query-smoke.mjs",
    "validate:claudekit-source-graph": "node scripts/knowledge/validate-claudekit-source-graph.mjs",
    "validate:claudekit-source-graph:wave1": "node scripts/knowledge/validate-claudekit-source-graph.mjs --profile wave1",
    "test:unit": "TMPDIR=.tmp vitest run tests/unit",
    "test:integration": "TMPDIR=.tmp vitest run tests/integration"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
