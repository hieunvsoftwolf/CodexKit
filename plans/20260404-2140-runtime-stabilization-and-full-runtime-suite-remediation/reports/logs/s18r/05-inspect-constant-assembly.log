    75	    fields.push({ source: "handoffCommand", rawValue: input.handoffCommand.trim() });
    76	  }
    77	  if (input.planPath.trim().length > 0) {
    78	    fields.push({ source: "planPath", rawValue: input.planPath.trim() });
    79	  }
    80	  if (input.mode.trim().length > 0) {
    81	    fields.push({ source: "mode", rawValue: input.mode.trim() });
    82	  }
    83	  for (let index = 0; index < input.diagnostics.length; index += 1) {
    84	    const nextStep = input.diagnostics[index]?.nextStep;
    85	    if (typeof nextStep === "string" && nextStep.trim().length > 0) {
    86	      fields.push({ source: `diagnostics[${index}].nextStep`, rawValue: nextStep.trim() });
    87	    }
    88	  }
    89	  return fields;
    90	}
