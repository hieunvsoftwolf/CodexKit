#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENTRYPOINT="${SCRIPT_DIR}/dist/packages/codexkit-cli/src/index.js"

if [[ ! -f "${ENTRYPOINT}" ]]; then
  echo "Missing compiled CLI entrypoint at ${ENTRYPOINT}." >&2
  echo "Run npm run build before invoking cdx from the workspace checkout." >&2
  exit 1
fi

exec node "${ENTRYPOINT}" "$@"
