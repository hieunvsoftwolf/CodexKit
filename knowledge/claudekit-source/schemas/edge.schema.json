{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/claudekit-source/schemas/edge.schema.json",
  "title": "ClaudeKit Source Edge",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "kind", "from", "to", "status", "sourceRefs"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^edge\\.[a-z0-9_]+(\\.[a-z0-9_]+)+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "defines",
        "uses",
        "requires",
        "produces",
        "gated_by",
        "hands_off_to",
        "delegates_to",
        "references",
        "maps_to",
        "derived_from"
      ]
    },
    "from": {
      "type": "string",
      "minLength": 1
    },
    "to": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["seed", "active", "deprecated", "manual-review"]
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^evidence\\.[a-z0-9_]+(\\.[a-z0-9_]+)+$"
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
